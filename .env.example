NODE_ENV=development
PORT=4000
APP_NAME=NodejsAppProduction1
JWT_SECRET=change-me-default-dev-only
JWT_REFRESH_SECRET=change-me-default-refresh-dev-only
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REDIS_URL=redis://localhost:6379
MONGODB_URI='mongodb+srv://username:password@cluster.mongodb.net/NodejsAppProduction1?retryWrites=true&w=majority'
CLIENT_URL=*
LOG_LEVEL=info
LOG_FORMAT=json

# HTTP request logger: 'winston' (existing structured logger, default) or 'morgan' (Apache-style)
HTTP_LOGGER=winston
MORGAN_FORMAT=combined
MORGAN_SKIP_HEALTH_CHECK=true
MORGAN_IMMEDIATE=false

# OpenAPI / Swagger documentation
DOCS_ENABLED=true
DOCS_PATH=/api-docs

# Idempotency keys for safe retries
IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_KEY_HEADER=Idempotency-Key
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_LOCK_TTL_SECONDS=30

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=uploads
STORAGE_MAX_FILE_SIZE_MB=10
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# AWS S3 settings (required when STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_URL=

# Image processing (Sharp)
IMAGE_PROCESSING_ENABLED=false
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
IMAGE_QUALITY=80
IMAGE_OUTPUT_FORMAT=webp
IMAGE_VARIANTS=thumbnail:150x150:cover,medium:800x600:inside,large:1920x1080:inside

EMAIL_JOB_ENABLED=false
EMAIL_JOB_CRON=*/30 * * * * *
EMAIL_JOB_BATCH_SIZE=10
EMAIL_JOB_MAX_RETRIES=3

NOTIFICATION_JOB_ENABLED=false
NOTIFICATION_JOB_CRON=*/15 * * * * *
NOTIFICATION_JOB_BATCH_SIZE=20
NOTIFICATION_JOB_MAX_RETRIES=3
NOTIFICATION_CLEANUP_DAYS=30

REMINDER_JOB_ENABLED=false
REMINDER_JOB_CRON=0 */6 * * *
REMINDER_JOB_BATCH_SIZE=50
REMINDER_WINDOWS_MINUTES=1440,60,15
REMINDER_OVERDUE_ENABLED=true

# Distributed cron job locking (prevents duplicate runs across multiple server instances)
CRON_JOB_LOCK_TTL_SECONDS=60

# Event-driven event bus (disable to skip registering event handlers at startup)
EVENT_BUS_ENABLED=true

# Lightweight raw WebSocket server (ws) alongside Socket.IO
WS_ENABLED=true
WS_PORT=3001

RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTHENTICATED_MAX_REQUESTS=200

API_KEY_HEADER_NAME=X-API-Key
API_KEY_PREFIX=npak_
API_KEY_HASH_SALT_ROUNDS=10
API_KEY_MAX_KEYS_PER_USER=10
API_KEY_DEFAULT_EXPIRY_DAYS=365

# Database migrations and seeding
SEED_ALLOWED_ENVS=development,test,staging
