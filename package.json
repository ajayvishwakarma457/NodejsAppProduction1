{
  "name": "nodejs-app-production1",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "tsx watch src/server.ts",
    "build": "npm run clean && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "ci": "npm run format:check && npm run lint && npm run test && npm run build",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "preversion": "npm run ci",
    "postversion": "git push && git push --tags",
    "db:migrate": "tsx src/scripts/migrate.ts up",
    "db:migrate:down": "tsx src/scripts/migrate.ts down",
    "db:migrate:status": "tsx src/scripts/migrate.ts status",
    "db:seed": "tsx src/scripts/seed.ts run",
    "db:seed:status": "tsx src/scripts/seed.ts status",
    "db:setup": "tsx src/scripts/migrate-and-seed.ts",
    "deps:check": "ncu",
    "deps:check:minor": "ncu --target minor",
    "deps:check:major": "ncu --target major",
    "deps:update:patch": "ncu --target patch -u && npm install",
    "deps:update:minor": "ncu --target minor -u && npm install",
    "deps:update:major": "ncu --target major -u && npm install",
    "deps:update:interactive": "ncu -i"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.967.0",
    "@aws-sdk/s3-request-presigner": "3.967.0",
    "aws-sdk-client-mock": "4.1.0",
    "bcryptjs": "3.0.3",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.22.2",
    "express-rate-limit": "8.5.2",
    "helmet": "8.0.0",
    "http-status-codes": "2.3.0",
    "jsonwebtoken": "9.0.3",
    "mongoose": "8.24.0",
    "multer": "2.1.1",
    "node-cron": "4.2.1",
    "nodemailer": "8.0.10",
    "passport": "0.7.0",
    "passport-github2": "0.1.12",
    "passport-google-oauth20": "2.0.0",
    "redis": "4.7.0",
    "sharp": "0.34.5",
    "socket.io": "4.8.0",
    "zod": "3.23.8"
  },
  "overrides": {
    "eslint-visitor-keys": "4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.1.0",
    "@types/node": "22.7.4",
    "@types/node-cron": "3.0.11",
    "@types/nodemailer": "8.0.0",
    "@types/passport": "1.0.17",
    "@types/passport-github2": "1.2.9",
    "@types/passport-google-oauth20": "2.0.17",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "npm-check-updates": "18.3.1",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "5.6.2",
    "typescript-eslint": "8.61.0",
    "vitest": "3.2.6"
  }
}
