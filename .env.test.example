# Example environment variables for integration tests.
#
# Integration tests use their own default values defined in
# vitest.integration.config.ts. This file documents the variables you can
# override when running tests against custom infrastructure.
#
# Copy this file to .env.test and adjust values as needed. The integration
# test config sets process.env BEFORE the application loads dotenv, so values
# in .env.test will take precedence over the root .env file.

NODE_ENV=test
PORT=4000
APP_NAME=NodejsAppProduction1
JWT_SECRET=integration-test-jwt-secret-32chars!
JWT_REFRESH_SECRET=integration-test-refresh-secret-32!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Test database (MUST be separate from production/development databases)
MONGODB_URI=mongodb://127.0.0.1:27017/nodejs-app-production1-integration-test

# Test Redis instance
REDIS_URL=redis://localhost:6379

CLIENT_URL=*
LOG_LEVEL=error

# Local file storage for file upload tests
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=uploads
STORAGE_MAX_FILE_SIZE_MB=10
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Disable background jobs and real-time services during tests
EMAIL_JOB_ENABLED=false
NOTIFICATION_JOB_ENABLED=false
REMINDER_JOB_ENABLED=false
IMAGE_PROCESSING_ENABLED=false
EVENT_BUS_ENABLED=false
WS_ENABLED=false
RATE_LIMIT_ENABLED=false

# API key configuration
API_KEY_HEADER_NAME=X-API-Key
API_KEY_PREFIX=npak_
API_KEY_HASH_SALT_ROUNDS=10
API_KEY_MAX_KEYS_PER_USER=10
API_KEY_DEFAULT_EXPIRY_DAYS=365

SEED_ALLOWED_ENVS=development,test,staging
