# ============================================================
# Production-grade npm configuration — Industry Standard
# ============================================================

# ------------------------------------------------------------------
# 1. SECURITY
# ------------------------------------------------------------------

# Enforce HTTPS for all registry communication
strict-ssl=true

# Block installs if Node/npm version doesn't match package.json engines
engine-strict=true

# Explicitly set the default public registry (prevents registry hijacking)
registry=https://registry.npmjs.org/

# Ignore postinstall / lifecycle scripts unless explicitly allowed.
# Prevents supply-chain attacks via malicious postinstall scripts.
# NOTE: If you install packages that require native compilation (e.g., bcrypt,
# sharp, node-sass), you must either allow scripts for those specific packages
# or build them separately.
ignore-scripts=true

# ------------------------------------------------------------------
# 2. DETERMINISTIC & REPRODUCIBLE BUILDS
# ------------------------------------------------------------------

# Always generate and respect lockfile (never skip it)
package-lock=true

# Use modern lockfile format (cross-platform, deterministic)
lockfile-version=3

# Pin exact versions on `npm install` (no ^ or ~)
save-exact=true

# ------------------------------------------------------------------
# 3. CI/CD OPTIMIZATION
# ------------------------------------------------------------------

# Disable progress bar (clutters CI logs, slows TTY-less environments)
progress=false

# Reduce log verbosity in automated environments
loglevel=warn

# Suppress funding messages
fund=false

# Disable update available notifications
update-notifier=false

# ------------------------------------------------------------------
# 4. PERFORMANCE & RESILIENCE
# ------------------------------------------------------------------

# Prefer locally cached packages over network fetch
prefer-offline=true

# Network retry configuration for flaky CI/build environments
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Maximum concurrent socket connections to registry
maxsockets=10

# ------------------------------------------------------------------
# 5. DEPENDENCY RESOLUTION
# ------------------------------------------------------------------

# Modern peer dependency resolution (npm 7+)
# Fail fast on peer dependency conflicts instead of auto-installing
legacy-peer-deps=false

# Deduplicate dependencies where possible
prefer-dedupe=true

# ------------------------------------------------------------------
# 6. AUDIT & COMPLIANCE
# ------------------------------------------------------------------

# Treat moderate+ vulnerabilities as install failures
audit-level=moderate
